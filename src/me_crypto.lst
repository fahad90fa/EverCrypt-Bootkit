                                      1 ;;; ===========================================================================
                                      2 ;;; EverCrypt ME Crypto Module
                                      3 ;;; ===========================================================================
                                      4 
                                      5         .module me_crypto
                                      6         
                                      7         .area   CSEG    (CODE)
                                      8 
                                      9 ;;; ===========================================================================
                                     10 ;;; ENCRYPT_BLOCK - Simple encryption
                                     11 ;;; Input: R0 = input, R1 = output
                                     12 ;;; ===========================================================================
                                     13 
                                     14         .globl  encrypt_block
                                     15 
      000000                         16 encrypt_block:
      000000 7F 10            [12]   17         mov     r7, #16
                                     18 
      000002                         19 enc_loop:
      000002 E6               [12]   20         mov     a, @r0
      000003 64 63            [12]   21         xrl     a, #0x63
      000005 6F               [12]   22         xrl     a, r7
      000006 F7               [12]   23         mov     @r1, a
      000007 08               [12]   24         inc     r0
      000008 09               [12]   25         inc     r1
      000009 DF F7            [24]   26         djnz    r7, enc_loop
      00000B 22               [24]   27         ret
