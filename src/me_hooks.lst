                                      9 ;;; ===========================================================================
                                     10 ;;; PATCH_RUNTIME - Additional DXE patches
                                     11 ;;; ===========================================================================
                                     12 
                                     13         .globl  patch_runtime
                                     14 
      000000                         15 patch_runtime:
      000000 90 10 20         [24]   16         mov     dptr, #0x1020
      000003 74 C3            [12]   17         mov     a, #0xC3        ; RET
      000005 F0               [24]   18         movx    @dptr, a
      000006 22               [24]   19         ret
